# SECUREWAY Backend Environment Configuration
# Copy this file to .env and configure your API keys

# OpenRouter API Key (Optional - for real AI analysis)
# Get free API key from https://openrouter.ai/
# If not configured, the system will use mock analysis
OPENROUTER_API_KEY=sk-or-v1-your-actual-api-key-here

# Other optional services (for future expansion)
# GEMINI_API_KEY=your-gemini-key
# PRESIDIO_API_KEY=your-presidio-key

# Remote SSH Configuration for Kali Machine
REMOTE_SSH_HOST=your-kali-ip
REMOTE_SSH_USER=your-ssh-username
REMOTE_SSH_KEY_PATH=C:/path/to/your/id_ed25519
REMOTE_SSH_PORT=22
